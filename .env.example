# Copy to `.env` and fill in. `.env` is git-ignored. NEVER commit real secrets.

# --- Frontier model APIs (L4 agent + eval frontier baselines) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Experiment tracking (Weights & Biases) ---
WANDB_API_KEY=
# online | offline | disabled  (use `offline` on air-gapped compute nodes)
WANDB_MODE=online

# --- DVC S3 remote (data + model artifacts) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Backend -> model server (DGX Spark in dev, cloud GPU in prod) ---
MODEL_SERVER_URL=http://127.0.0.1:8001
